    <item>
      <title>Chrome插件如何安全调用AI</title>
      <link>https://dev.infiniteevo.online/post/ai-interview/chrome%E6%8F%92%E4%BB%B6%E5%A6%82%E4%BD%95%E5%AE%89%E5%85%A8%E8%B0%83%E7%94%A8ai/</link>
