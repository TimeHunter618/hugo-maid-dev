    <item>
      <title>Token 成本监控与优化</title>
      <link>https://dev.infiniteevo.online/post/llm/8-%E8%BF%90%E7%BB%B4%E4%B8%8E%E5%8F%AF%E8%A7%82%E6%B5%8B%E6%80%A7/token%E6%88%90%E6%9C%AC%E7%9B%91%E6%8E%A7/</link>
